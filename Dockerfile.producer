# ── Producer Dockerfile ────────────────────────────────────────────────────────
FROM python:3.12-slim

WORKDIR /code

COPY app/producer/requirements.txt /code/requirements.txt
RUN pip install --no-cache-dir -r /code/requirements.txt

COPY app/ /code/app/

ENV PYTHONPATH=/code

CMD ["python", "-m", "app.producer.main"]
